{
  "name": "taskvision",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    ".",
    "../chrome-extension",
    "../shared"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint . --fix",
    "prepare": "husky || true",
    "serve": "firebase emulators:start",
    "deploy": "firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:app": "firebase deploy --only hosting",
    "create-apphosting": "firebase apphosting:backends:create --project taskvision-3f130 --location us-central1",
    "get-apphosting": "firebase apphosting:backends:get --project taskvision-3f130",
    "knip": "knip"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@shadcn/ui": "^0.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.1",
    "lucide-react": "^0.561.0",
    "next": "^16.0.10",
    "next-intl": "^4.6.0",
    "next-pwa": "^5.6.0",
    "react": "^19.0.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.0.3",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "taskvision-shared": "file:../shared"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.22.0",
    "@heroicons/react": "^2.2.0",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "daisyui": "^5.5.13",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
